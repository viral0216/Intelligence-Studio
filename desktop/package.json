{
  "name": "intelligence-studio-desktop",
  "version": "1.0.0",
  "description": "Intelligence Studio Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "author": "Intelligence Studio",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "electron-notarize": "^1.2.2"
  },
  "build": {
    "appId": "com.intelligence.studio",
    "productName": "Intelligence Studio",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "build/icon.png"
    ],
    "extraResources": [
      {
        "from": "../frontend/dist",
        "to": "frontend"
      }
    ],
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        { "target": "zip", "arch": ["arm64"] },
        { "target": "dir", "arch": ["arm64"] }
      ],
      "category": "public.app-category.developer-tools",
      "sign": {
        "entitlements": "build/entitlements.mac.plist",
        "entitlementsInherit": "build/entitlements.mac.plist"
      },
      "identity": null,
      "signingCerts": null
    },
    "afterSign": "./scripts/notarize.js",
    "notarize": {
      "teamId": "${APPLE_TEAM_ID}"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        { "target": "nsis" },
        { "target": "portable" }
      ]
    }
  }
}
